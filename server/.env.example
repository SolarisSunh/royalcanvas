PORT=4000
# Sustituye {tu_usuario} y {tu_contraseña} por tus credenciales de Azure SQL. No subas .env a GitHub.
DATABASE_URL=Server=tcp:royalcanvas-sql.database.windows.net,1433;Initial Catalog=royalcanvasdb;Persist Security Info=False;User ID={tu_usuario};Password={tu_contraseña};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

